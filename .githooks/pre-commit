#!/bin/sh
#
# Pre-commit hook - fast scan of LINES ADDED in this commit (not whole files).
#
# Why diff-only: the repo has pre-existing em-dashes in 10 files (legacy
# audit docs + bundled vendor JS). A whole-file scan would block every
# commit forever; a diff-only scan enforces the rule going forward and
# leaves cleanup as a separate scope.
#
# Mirrors the cheap Stage 1.1 checks from .github/copilot-instructions.md:
#   - Em-dash (U+2014) ban       - project character rule
#   - console.log ban in prod TS - Stage 1.1 Step 3.3
#   - Hardcoded secret regex     - Stage 1.1 Step 3.2
#
# Designed to be <5 seconds on a normal commit.
#
# Bypass (banned by standing rule, mechanism kept for emergencies):
#   git commit --no-verify -m "..."

# Defensive: the three checks below pipe through `grep`. If grep is missing
# (rare, but possible if the hook is invoked through a bare sh.exe outside
# Git-for-Windows' bundled MSYS2 PATH), the previous behavior was silent-pass
# (the `if ... | grep ... >/dev/null 2>&1` branch evaluates false, hits stay
# empty, exit 0). That would let em-dashes / console.log / secrets leak
# through. Fail loud instead.
for tool in grep git sed; do
    if ! command -v "$tool" >/dev/null 2>&1; then
        echo "[pre-commit] FATAL: required tool '$tool' not on PATH." >&2
        echo "[pre-commit] If invoked outside 'git commit' (e.g. via bare sh.exe), prepend Git's usr/bin to PATH first." >&2
        exit 1
    fi
done

# Files staged for this commit (Added/Copied/Modified/Renamed - no deletes)
staged=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged" ]; then
    exit 0
fi

fail=0
emdash=$(printf '\xe2\x80\x94')    # UTF-8 for U+2014 EM DASH

# Helper: extract just the ADDED lines from staged diff for one file.
# Lines start with '+' but exclude the '+++ b/path' header line.
added_lines_for() {
    git diff --cached -U0 -- "$1" | grep '^+' | grep -v '^+++'
}

# -------------------------------------------------------------------------
# Check 1: Em-dash in added lines (all text file types)
# -------------------------------------------------------------------------
emdash_hits=""
for f in $staged; do
    case "$f" in
        *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs|*.json|*.md|*.ps1|*.psm1|*.psd1|*.yml|*.yaml|*.html|*.css|*.scss|*.sh)
            if [ -f "$f" ]; then
                added=$(added_lines_for "$f")
                if echo "$added" | grep -F "$emdash" >/dev/null 2>&1; then
                    emdash_hits="$emdash_hits $f"
                fi
            fi
            ;;
    esac
done

if [ -n "$emdash_hits" ]; then
    echo ""
    echo "[pre-commit] FAIL: em-dash (U+2014) ADDED in staged diff (use hyphen '-' instead):" >&2
    for f in $emdash_hits; do
        echo "  $f" >&2
        added_lines_for "$f" | grep -nF "$emdash" | head -3 | sed 's/^/    /' >&2
    done
    fail=1
fi

# -------------------------------------------------------------------------
# Check 2: console.log/debug/info added to production TS/JS
# -------------------------------------------------------------------------
console_hits=""
for f in $staged; do
    case "$f" in
        api/src/*.ts|api/src/**/*.ts|web/src/*.ts|web/src/*.tsx|web/src/**/*.ts|web/src/**/*.tsx)
            case "$f" in
                *.spec.ts|*.spec.tsx|*.test.ts|*.test.tsx|*/test/*|*/tests/*|*/__tests__/*) continue ;;
            esac
            if [ -f "$f" ]; then
                added=$(added_lines_for "$f")
                if echo "$added" | grep -E "(^|[^.])console\.(log|debug|info)" >/dev/null 2>&1; then
                    console_hits="$console_hits $f"
                fi
            fi
            ;;
    esac
done

if [ -n "$console_hits" ]; then
    echo ""
    echo "[pre-commit] FAIL: console.log/debug/info ADDED to production code (use Logger):" >&2
    for f in $console_hits; do
        echo "  $f" >&2
        added_lines_for "$f" | grep -nE "(^|[^.])console\.(log|debug|info)" | head -3 | sed 's/^/    /' >&2
    done
    fail=1
fi

# -------------------------------------------------------------------------
# Check 3: Hardcoded secret regex in added lines
# -------------------------------------------------------------------------
secret_re='AKIA[0-9A-Z]{16}|sk_live_[0-9a-zA-Z]{24,}|ghp_[0-9a-zA-Z]{36}|gho_[0-9a-zA-Z]{36}|xox[baprs]-[0-9a-zA-Z-]{10,}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----'
secret_hits=""
for f in $staged; do
    case "$f" in
        *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs|*.json|*.yml|*.yaml|*.env|*.ps1|*.sh)
            if [ -f "$f" ]; then
                added=$(added_lines_for "$f")
                if echo "$added" | grep -E "$secret_re" >/dev/null 2>&1; then
                    secret_hits="$secret_hits $f"
                fi
            fi
            ;;
    esac
done

if [ -n "$secret_hits" ]; then
    echo ""
    echo "[pre-commit] FAIL: probable hardcoded secret ADDED in staged diff:" >&2
    for f in $secret_hits; do
        echo "  $f" >&2
        added_lines_for "$f" | grep -nE "$secret_re" | head -3 | sed 's/^/    /' >&2
    done
    fail=1
fi

# -------------------------------------------------------------------------
# Result
# -------------------------------------------------------------------------
if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "[pre-commit] Commit blocked. Fix the issues above or bypass with 'git commit --no-verify' (banned by standing rule)." >&2
    exit 1
fi

exit 0
