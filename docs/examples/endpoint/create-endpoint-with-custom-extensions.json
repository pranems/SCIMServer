  "_13_patch_add_extension_to_existing_endpoint": {
    "_comment": "PATCH /scim/admin/endpoints/{id} — Add extension to an existing endpoint. NOTE: schemas + resourceTypes must be sent together (replace semantics)",
    "_method": "PATCH",
    "_path": "/scim/admin/endpoints/{id}",
    "profile": {
      "schemas": [
        { "id": "urn:ietf:params:scim:schemas:core:2.0:User", "name": "User", "attributes": "all" },
        { "id": "urn:ietf:params:scim:schemas:core:2.0:Group", "name": "Group", "attributes": "all" },
        {
          "id": "urn:example:scim:extension:newext:2.0:User",
          "name": "NewExtension",
          "description": "Extension added after initial creation",
          "attributes": [
            { "name": "newField", "type": "string", "multiValued": false, "required": false, "mutability": "readWrite", "returned": "default", "caseExact": false, "uniqueness": "none" }
          ]
        }
      ],
      "resourceTypes": [
        { "id": "User", "name": "User", "endpoint": "/Users", "description": "User",
          "schema": "urn:ietf:params:scim:schemas:core:2.0:User",
          "schemaExtensions": [{ "schema": "urn:example:scim:extension:newext:2.0:User", "required": false }] },
        { "id": "Group", "name": "Group", "endpoint": "/Groups", "description": "Group",
          "schema": "urn:ietf:params:scim:schemas:core:2.0:Group", "schemaExtensions": [] }
      ]
    }
  },


  "_usage_create_user_with_extension": {
    "_comment": "POST /scim/endpoints/{endpointId}/Users — Create user with extension data (use with any endpoint above)",
    "_method": "POST",
    "_path": "/scim/endpoints/{endpointId}/Users",
    "schemas": [
      "urn:ietf:params:scim:schemas:core:2.0:User",
      "urn:example:scim:extension:hr:2.0:User"
    ],
    "userName": "jdoe@example.com",
    "displayName": "John Doe",
    "active": true,
    "name": { "givenName": "John", "familyName": "Doe" },
    "emails": [{ "value": "jdoe@example.com", "type": "work", "primary": true }],
    "urn:example:scim:extension:hr:2.0:User": {
      "badgeNumber": "B12345",
      "costCenter": "Engineering",
      "secretToken": "mysecret",
      "tags": ["vip", "engineering"]
    }
  },


  "_usage_patch_extension_attribute": {
    "_comment": "PATCH /scim/endpoints/{endpointId}/Users/{userId} — Patch extension attribute",
    "_method": "PATCH",
    "_path": "/scim/endpoints/{endpointId}/Users/{userId}",
    "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
    "Operations": [
      { "op": "replace", "value": { "urn:example:scim:extension:hr:2.0:User": { "badgeNumber": "B99999" } } }
    ]
  },


  "_usage_patch_extension_by_path": {
    "_comment": "PATCH with URN-prefixed path targeting a single extension attribute",
    "_method": "PATCH",
    "_path": "/scim/endpoints/{endpointId}/Users/{userId}",
    "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
    "Operations": [
      { "op": "replace", "path": "urn:example:scim:extension:hr:2.0:User:costCenter", "value": "Sales" }
    ]
  },


  "_usage_create_group_with_extension": {
    "_comment": "POST /scim/endpoints/{endpointId}/Groups — Create group with extension data",
    "_method": "POST",
    "_path": "/scim/endpoints/{endpointId}/Groups",
    "schemas": [
      "urn:ietf:params:scim:schemas:core:2.0:Group",
      "urn:example:scim:extension:dept:2.0:Group"
    ],
    "displayName": "Engineering Team",
    "urn:example:scim:extension:dept:2.0:Group": {
      "department": "Engineering",
      "costCode": "ENG-001"
    }
  }
}
