{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "./",
    "baseUrl": "./",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    // TypeScript 6 deprecates 'baseUrl' and 'moduleResolution: node' (TS 7 removal).
    // We acknowledge the deprecation here; the proper migration to 'paths' alone +
    // 'moduleResolution: bundler' is tracked separately and out of scope for the
    // dependency-bump consolidation.
    "ignoreDeprecations": "6.0",
    "types": ["node", "jest"],
    "paths": {
      "@app/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
