{
  "name": "scimserver-api",
  "version": "0.52.3",
  "description": "SCIMServer backend service providing SCIM 2.0 endpoints and logging for troubleshooting.",
  "license": "MIT",
  "main": "dist/main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "npx prisma migrate deploy && node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:debug": "npx ts-node-dev --respawn --transpile-only --inspect=9229 src/main.ts",
    "start:debug:log": "npx ts-node-dev --respawn --transpile-only --inspect=9229 src/main.ts 2>&1 | tee scimserver.log",
    "lint": "eslint ./src",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config test/e2e/jest-e2e.config.ts --forceExit",
    "test:e2e:cov": "jest --config test/e2e/jest-e2e.config.ts --coverage --forceExit",
    "test:cov:all": "npm run test:cov && npm run test:e2e:cov",
    "test:smoke": "pwsh ../scripts/live-test.ps1",
    "test:all": "npm test && npm run test:e2e && npm run test:smoke",
    "test:ci": "npm test && npm run test:e2e",
    "build:standalone": "pwsh ../scripts/build-standalone.ps1",
    "build:standalone:zip": "pwsh ../scripts/build-standalone.ps1 -Zip",
    "build:standalone:full": "pwsh ../scripts/build-standalone.ps1 -IncludeNode -Zip",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "check:trivyignore": "ts-node --transpile-only src/scripts/check-trivyignore.ts",
    "mirror:prod-to-dev": "ts-node --transpile-only src/scripts/mirror-prod-to-dev.ts",
    "seed:shape-coverage": "ts-node --transpile-only src/scripts/seed-shape-coverage.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.2.4",
    "helmet": "^8.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "// overrides": "OPS-3 / Trivy gate: pin transitive deps to patched versions for known HIGH CVEs. Each entry MUST cite the CVE so future maintainers can drop it once the upstream chain catches up. Reviewed 2026-04-30. See .github/workflows/build-and-push.yml Trivy step.",
  "overrides": {
    "@hono/node-server": "1.19.10",
    "defu": "6.1.5",
    "effect": "3.20.0",
    "hono": "4.12.4",
    "multer": "2.1.1",
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4"
  }
}
