            "schema": "urn:ietf:params:scim:schemas:extension:msfttest:Group",
            "required": false
          }
        ]
      }
    ],
    "serviceProviderConfig": {
      "patch": {
        "supported": true
      },
      "bulk": {
        "supported": false
      },
      "filter": {
        "supported": true,
        "maxResults": 200
      },
      "sort": {
        "supported": false
      },
      "etag": {
        "supported": true
      },
      "changePassword": {
        "supported": false
      }
    },
    "settings": {
      "AllowAndCoerceBooleanStrings": "True",
      "StrictSchemaValidation": "True",
      "PrimaryEnforcement": "normalize"
    }
  }
